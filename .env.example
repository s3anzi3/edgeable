# Edgeable client env vars (Vite). Copy to `.env` (gitignored) and fill in.
# These are inlined into the client bundle at BUILD time, so re-run `npm run build`
# after changing them.

# Firebase App Check — reCAPTCHA Enterprise *site* key (public; not a secret).
# Create it in the Firebase console: Build > App Check > Apps > register the web
# app with reCAPTCHA Enterprise. Leaving this unset disables App Check entirely.
VITE_APPCHECK_RECAPTCHA_KEY=

# Local-dev only: set to "true" to print an App Check debug token in the browser
# console, which you then register under App Check > Apps > Manage debug tokens.
# Leave unset for production builds.
VITE_APPCHECK_DEBUG_TOKEN=
