rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Proof-of-payment images (transactions and pending transaction requests).
    // Both /transaction-proofs/<file> and /transaction-proofs/requests/<file>.
    // Reads/deletes: any signed-in user. Uploads: images only, under 20 MB, so
    // the bucket can't be used to host arbitrary files or run up storage costs.
    match /transaction-proofs/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (
          // deletes carry no incoming file
          request.resource == null
          // uploads must be an image under 20 MB
          || (request.resource.size < 20 * 1024 * 1024
              && request.resource.contentType.matches('image/.*'))
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
